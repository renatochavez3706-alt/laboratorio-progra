#include<iostream>
using namespace std;
int main(){
    int opcion;
    float celsius, fahrenheit, kelvin, rankine;
    cout <<"ingrese la cantidad de grados celsius: "<<endl;
    cin>>celsius;
    cout <<"seleccione a que escala quiere transformar: "<<endl;
    cout <<"1. Fahrenheit"<<endl;
    cout <<"2. Kelvin"<<endl;
    cout <<"3. Rankine"<<endl;
    cout <<"Ingrese opcion: "<<endl;
    cin>>opcion;
    switch(opcion){
    case 1:
        fahrenheit=(celsius*(9/5))+32;
        cout << "celsius a fahrenheit: "<<fahrenheit<<endl;
        break;
    case 2:
        kelvin=celsius+273.15;
        cout << "celsius a kelvin: "<<kelvin<<endl;
        break;
    case 3:
        rankine=(celsius*(9/5))+491.67;
        cout << "celsius a rankine: "<<rankine<<endl;
        break;
        default:
        cout<<"ERROR"<<endl;
    }
    return 0;
}
