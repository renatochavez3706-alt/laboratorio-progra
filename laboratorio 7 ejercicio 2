#include <iostream>
#include <cmath>
using namespace std;
int main() {
    int n;
    double x, suma = 0, valor;
    cin >> x >> n;
    cout << "cosh(" << x << ") = ";
    for (int i = 0; i < n; i++) {
        int fact = 1;
        for (int j = 1; j <= 2*i; j++) {
            fact = fact * j;
        }
        valor = pow(x, 2*i) / fact;

        cout << valor;
        if (i < n-1) cout << " + ";
        suma = suma + valor;
    }
    cout << endl;
    cout << "Resultado = " << suma<< endl;
    return 0;
}
