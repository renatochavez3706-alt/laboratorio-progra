#include<iostream>
#include<iomanip>
int sumahastaN(int N);
using namespace std;
int main(){
int N,suma;
cout<<"ingrese N: "<<endl;
cin>>N;
suma=sumahastaN(N);
cout<<fixed<<setprecision(0);
cout<<"la suma es: "<<suma<<endl;
